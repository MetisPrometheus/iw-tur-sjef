# Postgres on iw-infra box. Local dev pulls this from /etc/tur-sjef/env after
# `sudo bash /opt/projects/iw-infra/setup.sh tur-sjef` has been run.
DATABASE_URL=postgresql://tur_sjef_rw:PASSWORD@127.0.0.1:5432/tur_sjef

# Google Places (server-side only — never NEXT_PUBLIC_)
GOOGLE_PLACES_API_KEY=

# Mapbox (public token; used in browser)
NEXT_PUBLIC_MAPBOX_TOKEN=
